   the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0\n        the top 1.0\n        the bottom 1.0\n        the middle 1.0\n        the top 1.0\n        the bottom 1.0"
