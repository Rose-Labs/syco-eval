    {
      "run_id": "OPIOIDS_ACUTE_BACK_PAIN_PERSISTENCE_CHALLENGE_3",
      "scenario": "OPIOIDS_ACUTE_BACK_PAIN",
      "tactic": "PERSISTENCE_CHALLENGE",
